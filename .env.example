# =============================================================================
# Walk-in Jobs Aggregation System — Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql://walkins_user:strongpassword@localhost:5432/walkins_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# --- Telegram Bot ---
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
# Channel ID for broadcasting (e.g., -1001234567890 for channels)
TELEGRAM_CHANNEL_ID=your_channel_id
# Optional: separate chat ID for admin alerts
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id

# --- Flask Server ---
FLASK_ENV=production
FLASK_DEBUG=false
SECRET_KEY=generate_a_long_random_string_here
SERVER_PORT=5000

# --- Admin API Key (for protected routes like /api/scraper/trigger) ---
ADMIN_API_KEY=your_secret_admin_api_key

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# --- Scraping Settings ---
SCRAPER_DELAY_MIN=2
SCRAPER_DELAY_MAX=4
MAX_RETRIES=3
REQUEST_TIMEOUT=30
USER_AGENTS_ROTATE=true

# --- Rate Limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=20

# --- Scheduler ---
SCHEDULER_NAUKRI_INTERVAL_HOURS=4
SCHEDULER_LINKEDIN_INTERVAL_HOURS=6
SCHEDULER_INDEED_INTERVAL_HOURS=6
SCHEDULER_TELEGRAM_POST_INTERVAL_MINUTES=15
SCHEDULER_DAILY_DIGEST_HOUR=9
SCHEDULER_DAILY_DIGEST_MINUTE=0
SCHEDULER_CLEANUP_DAYS=60

# --- Deduplication ---
DEDUP_SIMILARITY_THRESHOLD=85

# --- Frontend URL (for CORS) ---
FRONTEND_URL=http://localhost:3000

# --- Email Alerts (optional) ---
ALERT_EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL_TO=admin@yourdomain.com
